# Build context: monorepo/ (run with docker build -f services/{{ service_name }}/Dockerfile .)

# ---------------------------------------------------------------------------
# Stage 1 — builder (install service dependencies into /opt/venv)
# ---------------------------------------------------------------------------
FROM tdp-python-base AS builder

USER root
WORKDIR /build

# Copy platform libraries (path must match relative reference in pyproject.toml)
COPY libs/tdp-fastapi-core ./libs/tdp-fastapi-core

# Copy service dependency manifests and install
COPY services/{{ service_name }}/pyproject.toml services/{{ service_name }}/uv.lock ./services/{{ service_name }}/
WORKDIR /build/services/{{ service_name }}
ENV UV_PROJECT_ENVIRONMENT="/opt/venv"
RUN uv sync --frozen --no-dev --no-editable

# ---------------------------------------------------------------------------
# Stage 2 — runtime (slim image with only app code)
# ---------------------------------------------------------------------------
FROM tdp-python-base AS runtime

USER root

# Copy the virtualenv with all installed dependencies from builder
COPY --from=builder /opt/venv /opt/venv

WORKDIR /app

# Copy application source and supporting files
COPY services/{{ service_name }}/src/ ./src/
COPY services/{{ service_name }}/logging_config.py ./
COPY services/{{ service_name }}/entrypoint.sh ./
{% if use_gunicorn %}
COPY services/{{ service_name }}/gunicorn_conf.py ./
{% endif %}

RUN chmod +x ./entrypoint.sh

# Drop back to non-root for runtime
USER app

EXPOSE {{ service_port }}

CMD ["./entrypoint.sh"]
