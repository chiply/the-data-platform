# CI/headless environments only. For local development, use `pulumi login` instead.
# .env is gitignored and should never be committed.

# Pulumi Cloud access token (CI only — local dev uses `pulumi login`)
# Get one at: https://app.pulumi.com → Settings → Access Tokens
PULUMI_ACCESS_TOKEN=pul-xxxxx

# Infrastructure secrets (LINODE_TOKEN, root passwords, Grafana password) are
# managed via Pulumi ESC environments (tdp/dev, tdp/production).
# See: https://app.pulumi.com → Environments
#
# To add or update a secret:
#   pulumi env set chiply-org/tdp/dev --secret pulumiConfig.<key> <value>
#
# To view current secrets:
#   pulumi env open chiply-org/tdp/dev
