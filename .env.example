# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.

# Pulumi Cloud access token (required for all infra operations)
# Get one at: https://app.pulumi.com → Settings → Access Tokens
PULUMI_ACCESS_TOKEN=pul-xxxxx

# Linode/Akamai API token (only needed for production deployments)
# Get one at: https://cloud.linode.com → My Profile → API Tokens
LINODE_TOKEN=

# Root password for the production k3s Linode instance
# Generate a strong password: openssl rand -base64 24
LINODE_ROOT_PASSWORD=

# Grafana admin password for production monitoring stack
# Generate a strong password: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=
