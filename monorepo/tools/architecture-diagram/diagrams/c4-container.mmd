C4Container
    title Container diagram for The Data Platform

    Person(user, "Platform User", "Developer or content consumer who submits feeds and views aggregated content")

    System_Ext(rss, "RSS Feed Sources", "External content sources: YouTube, Reddit, X, PubMed, blogs, newsletters")

    System_Boundary(platform, "The Data Platform") {
        Container(feed_reader, "Feed Reader Service", "FastAPI", "Ingests RSS/Atom feeds, extracts content, and summarizes articles")
        Container(schema_registry, "Schema Registry", "FastAPI", "Centralized schema versioning and compatibility checks for Avro/Protobuf schemas")
        Container(broker, "Intelligent Broker", "Python", "Schema-to-schema transformation between services, decoupling producers and consumers")
        Container(search, "Search Service", "FastAPI", "Semantic search across ingested and summarized content")
        Container(temporal, "Temporal", "Workflow Engine", "Event-driven and long-running durable workflow orchestration")
        Container(dagster, "Dagster", "Pipeline Orchestrator", "Batch and data pipeline orchestration with asset-based lineage")
        Container(k8s, "Kubernetes", "Container Orchestration", "Shared compute layer for all deployed services and workers")
        Container(pulumi, "Pulumi", "Infrastructure as Code", "Defines and provisions shared infrastructure: clusters, networking, storage, observability")
    }

    Rel(user, feed_reader, "Submits feed URLs, views content")
    Rel(user, search, "Searches across ingested content")
    Rel(feed_reader, rss, "Fetches feeds from")
    Rel(feed_reader, temporal, "Triggers content extraction and summarization workflows")
    Rel(feed_reader, schema_registry, "Publishes and resolves schemas")
    Rel(temporal, dagster, "Triggers batch pipelines for digest generation")
    Rel(dagster, feed_reader, "Reads ingested content for pipeline assets")
    Rel(feed_reader, broker, "Routes events through for schema transformation")
    Rel(broker, schema_registry, "Resolves schema mappings")
    Rel(search, feed_reader, "Indexes content from")
    Rel(pulumi, k8s, "Provisions and manages")
    Rel(feed_reader, k8s, "Deployed on")
    Rel(temporal, k8s, "Deployed on")
    Rel(dagster, k8s, "Deployed on")
    Rel(schema_registry, k8s, "Deployed on")
    Rel(broker, k8s, "Deployed on")
    Rel(search, k8s, "Deployed on")
